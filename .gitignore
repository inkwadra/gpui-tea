*~
*.swp
*.swo

# IDE and local workspace settings
.idea/
.vscode/
.direnv/
.envrc

# OS-generated files
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.Spotlight-V100/
.Trashes/
._*
