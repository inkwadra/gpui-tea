{
  "languages": {
    "Rust": {
      "formatter": "language_server",
      "format_on_save": "on"
    },
    "TOML": {
      "format_on_save": "on"
    },
    "JSON": {
      "formatter": "language_server",
      "format_on_save": "on"
    }
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "rust": {
          "analyzerTargetDir": true
        }
      }
    }
  },
  "tasks": {
    "prefer_lsp": false
  }
}
